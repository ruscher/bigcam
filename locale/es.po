msgstr "Cómo conectar tu teléfono"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 780
msgid "The easiest and fastest method."
msgstr "El método más fácil y rápido."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 781
msgid "1. On your Android phone, go to Settings → About Phone"
msgstr "1. En tu teléfono Android, ve a Configuración → Acerca del teléfono"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 782
msgid "2. Tap 'Build Number' 7 times to unlock Developer Options"
msgstr "2. Toca 'Número de compilación' 7 veces para desbloquear Opciones de desarrollador."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 783
msgid "3. Go to Settings → Developer Options → enable 'USB Debugging'"
msgstr "3. Ve a Configuración → Opciones de desarrollador → habilita 'Depuración USB'"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 784
msgid "4. Connect the USB cable to the computer"
msgstr "4. Conecta el cable USB al ordenador."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 785
msgid "5. Accept the USB Debugging prompt on the phone screen"
msgstr "5. Acepta el aviso de Depuración USB en la pantalla del teléfono."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 786
msgid "6. Click 'Start' on the USB tab"
msgstr "6. Haga clic en 'Iniciar' en la pestaña USB"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 788
msgid "No cable needed after the first setup."
msgstr "No se necesita cable después de la primera configuración."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 789
msgid "EASIEST: If connected via USB, use the wireless icon"
msgstr "MÁS FÁCIL: Si está conectado por USB, use el ícono inalámbrico."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 790
msgid "on the device selector to switch to Wi-Fi instantly."
msgstr "en el selector de dispositivos para cambiar a Wi-Fi instantáneamente."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 791
msgid "FIRST-TIME PAIRING (without USB):"
msgstr "EMPAREJAMIENTO POR PRIMERA VEZ (sin USB):"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 792
msgid "1. Enable Developer Options (same steps as USB above)"
msgstr "1. Habilitar Opciones de Desarrollador (mismos pasos que USB arriba)"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 793
msgid "2. Go to Settings → Developer Options → Wireless Debugging"
msgstr "2. Ve a Configuración → Opciones de desarrollador → Depuración inalámbrica"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 794
msgid "3. Tap 'Pair device with pairing code'"
msgstr "3. Toca 'Emparejar dispositivo con código de emparejamiento'"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 795
msgid "   ⚠ Use 'pairing CODE', NOT 'QR Code'"
msgstr "⚠ Utiliza 'CÓDIGO de emparejamiento', NO 'Código QR'"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 796
msgid "4. Note the IP:Port and 6-digit code shown on the phone"
msgstr "4. Toma nota de la IP:Puerto y el código de 6 dígitos que se muestra en el teléfono."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 797
msgid "5. On the Wi-Fi tab, expand 'Pair new device'"
msgstr "5. En la pestaña de Wi-Fi, expande 'Emparejar nuevo dispositivo'"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 798
msgid "6. Type the IP:Port and code, then tap 'Pair'"
msgstr "6. Escribe la IP:Puerto y el código, luego toca 'Emparejar'"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 799
msgid "   💡 Or tap 'Find' to auto-fill the IP:Port"
msgstr "💡 O toca 'Buscar' para completar automáticamente el IP:Puerto."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 800
msgid "7. After pairing, tap 'Scan' to find the device"
msgstr "7. Después de emparejar, toca 'Escanear' para encontrar el dispositivo."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 801
msgid "8. Click 'Start' on the Wi-Fi tab"
msgstr "8. Haga clic en 'Iniciar' en la pestaña de Wi-Fi"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 803
msgid "Mirrors the entire screen (not just the camera)."
msgstr "Refleja toda la pantalla (no solo la cámara)."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 804
msgid "1. Make sure both devices are on the same Wi-Fi network"
msgstr "Asegúrate de que ambos dispositivos estén en la misma red Wi-Fi."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 805
msgid "2. Click 'Start' on the AirPlay tab"
msgstr "2. Haga clic en 'Iniciar' en la pestaña AirPlay"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 806
msgid "3. On your iPhone, open Control Center (swipe down from top-right)"
msgstr "3. En tu iPhone, abre el Centro de Control (desliza hacia abajo desde la esquina superior derecha)"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 807
msgid "4. Tap 'Screen Mirroring' and select 'BigCam'"
msgstr "4. Toca 'Duplicar Pantalla' y selecciona 'BigCam'"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 809
msgid "Works with any phone, no app required."
msgstr "Funciona con cualquier teléfono, no se requiere aplicación."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 810
msgid "1. Connect both devices to the same Wi-Fi network"
msgstr "1. Conecta ambos dispositivos a la misma red Wi-Fi."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 811
msgid "2. Click 'Start' on the Browser tab"
msgstr "2. Haga clic en 'Iniciar' en la pestaña del Navegador"
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 812
msgid "3. Scan the QR code with your phone or type the URL"
msgstr "3. Escanea el código QR con tu teléfono o escribe la URL."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 813
msgid "4. Accept the security warning in the browser"
msgstr "4. Acepta la advertencia de seguridad en el navegador."
# 
# File: bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py, line: 814
msgid "5. Tap 'Start' on the phone's browser page"
msgstr "5. Toca 'Iniciar' en la página del navegador del teléfono."
