#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:778
msgid "How to connect your phone"
msgstr "Kuinka yhdistää puhelimesi"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:781
msgid "The easiest and fastest method."
msgstr "Helpoin ja nopein tapa."

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:782
msgid "1. On your Android phone, go to Settings → About Phone"
msgstr "1. Android-puhelimellasi siirry Asetukset → Puhelimesta"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:783
msgid "2. Tap 'Build Number' 7 times to unlock Developer Options"
msgstr "2. Napauta 'Build Number' 7 kertaa avataksesi Kehittäjäasetukset"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:784
msgid "3. Go to Settings → Developer Options → enable 'USB Debugging'"
msgstr ""
"3. Siirry Asetukset → Kehittäjäasetukset → ota käyttöön 'USB-virheenkorjaus'"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:785
msgid "4. Connect the USB cable to the computer"
msgstr "4. Liitä USB-kaapeli tietokoneeseen"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:786
msgid "5. Accept the USB Debugging prompt on the phone screen"
msgstr "5. Hyväksy USB-virheenkorjauskehotus puhelimen näytöllä"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:787
msgid "6. Click 'Start' on the USB tab"
msgstr "6. Napsauta 'Aloita' USB-välilehdellä"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:789
msgid "No cable needed after the first setup."
msgstr "Kaapelia ei tarvita ensimmäisen asennuksen jälkeen."

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:790
msgid "EASIEST: If connected via USB, use the wireless icon"
msgstr "HELPPOIN: Jos yhteys on USB:n kautta, käytä langatonta kuvaketta"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:791
msgid "on the device selector to switch to Wi-Fi instantly."
msgstr "laitevalitsimessa vaihtaaksesi Wi-Fi-tilaan välittömästi."

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:792
msgid "FIRST-TIME PAIRING (without USB):"
msgstr "ENSIMMÄINEN PARITUS (ilman USB:tä):"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:793
msgid "1. Enable Developer Options (same steps as USB above)"
msgstr "1. Ota kehittäjäasetukset käyttöön (samat vaiheet kuin USB:ssä yllä)"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:794
msgid "2. Go to Settings → Developer Options → Wireless Debugging"
msgstr ""
"2. Siirry kohtaan Asetukset → Kehittäjäasetukset → Langaton virheenkorjaus"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:795
msgid "3. Tap 'Pair device with pairing code'"
msgstr "3. Napauta 'Parita laite parituskoodilla'"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:796
msgid "   ⚠ Use 'pairing CODE', NOT 'QR Code'"
msgstr "⚠ Käytä 'paritusKOODIA', EI 'QR-koodia'"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:797
msgid "4. Note the IP:Port and 6-digit code shown on the phone"
msgstr "4. Kirjaa muistiin puhelimessa näkyvä IP:Port ja 6-numeroinen koodi"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:798
msgid "5. On the Wi-Fi tab, expand 'Pair new device'"
msgstr "5. Wi-Fi-välilehdellä laajenna 'Parita uusi laite'"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:799
msgid "6. Type the IP:Port and code, then tap 'Pair'"
msgstr "6. Kirjoita IP:Port ja koodi, napauta sitten 'Parita'"

#: /home/ruscher/Documentos/Git/_REFIZ/bigcam/usr/share/biglinux/bigcam/ui/phone_camera_dialog.py:800
msgid "   💡 Or tap 'Find' to auto-fill the IP:Port"
